# =============================================================
# Law-RAG-Agent 环境配置
# 复制此文件为 .env 后修改
# =============================================================

# ---- LLM 模型 ----
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# ---- Embedding 模型 ----
EMBED_MODEL=nomic-embed-text
EMBED_BASE_URL=http://localhost:11434
EMBED_BATCH_SIZE=32

# ---- 检索 ----
RETRIEVAL_TOP_K=5
# 是否启用混合检索 (向量 + BM25关键词)
RETRIEVAL_HYBRID_ENABLED=true
# 混合检索权重: BM25 权重 (0~1)，向量权重 = 1 - BM25权重
# 评估最优值 0.7，如换用更强的嵌入模型可降至 0.3-0.5
RETRIEVAL_BM25_WEIGHT=0.7

# ---- 向量索引 ----
INDEX_NAME=law_index
INDEX_DIR=data/vector_store

# ---- 服务 ----
HOST=0.0.0.0
PORT=8000

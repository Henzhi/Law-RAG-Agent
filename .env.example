# =============================================================
# Law-RAG-Agent 环境配置
# 复制此文件为 .env 后修改
# =============================================================

# ---- LLM 模型 ----
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# ---- Embedding 模型 ----
# bge-m3: BAAI 多语言 SOTA，中文法律检索评估 Recall@5=0.85
# 如需轻量模型可换 nomic-embed-text (Recall@5=0.30, 不推荐)
EMBED_MODEL=bge-m3
EMBED_BASE_URL=http://localhost:11434
EMBED_BATCH_SIZE=32

# ---- 检索 ----
RETRIEVAL_TOP_K=5
# bge-m3 语义检索已足够强，默认关闭混合检索减少干扰
# 如果用 nomic-embed-text 建议开启，BM25 权重 0.7
RETRIEVAL_HYBRID_ENABLED=false
RETRIEVAL_BM25_WEIGHT=0.0

# ---- 向量索引 ----
INDEX_NAME=law_index
INDEX_DIR=data/vector_store

# ---- LangGraph 多 Agent ----
# 开启后自动查询改写 + 答案校验防幻觉
AGENT_ENABLED=false
AGENT_MAX_RETRIES=1

# ---- pgvector (Docker) ----
# 开启后使用 PostgreSQL+pgvector 替代 FAISS
PG_ENABLED=false
PG_CONN=postgresql://lawrag:lawrag123@localhost:5432/lawrag

# ---- 重排序 (Reranker) ----
# 需要 sentence-transformers + torch，首次加载较慢（~2GB 模型）
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ---- 相邻法条扩展 ----
# 检索时自动补全前后 N 条法条，保持法律条文连续性
ADJACENT_ENABLED=true
ADJACENT_WINDOW=2

# ---- 服务 ----
HOST=0.0.0.0
PORT=8000
